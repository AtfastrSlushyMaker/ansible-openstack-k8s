  predictions.json: |
    {
      "title": "Pod Predictions (ML Forecasting)",
      "uid": "pod-predictions",
      "editable": true,
      "panels": [
        {
          "title": "Prediction Overview",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
          "collapsed": false
        },
        {
          "title": "Prediction Exporter Status",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
          "targets": [{ "expr": "up{job=\"prediction-exporter\"}", "legendFormat": "Exporter" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}] } }
        },
        {
          "title": "Prediction Horizon",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
          "targets": [{ "expr": "pod_prediction_horizon_minutes", "legendFormat": "Minutes" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "min" } }
        },
        {
          "title": "Pods Being Predicted",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
          "targets": [{ "expr": "count(pod_predicted_cpu_mean)", "legendFormat": "Count" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Active Recommendations",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
          "targets": [{ "expr": "count(pod_recommendation)", "legendFormat": "Count" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 3, "color": "red"}] } } }
        },
        {
          "title": "Avg CPU Prediction Confidence",
          "type": "gauge",
          "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
          "targets": [{ "expr": "avg(pod_prediction_confidence{metric=\"cpu\"})", "legendFormat": "CPU" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "steps": [{"value": 0, "color": "red"}, {"value": 0.5, "color": "yellow"}, {"value": 0.7, "color": "green"}] } } }
        },
        {
          "title": "Avg Memory Prediction Confidence",
          "type": "gauge",
          "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
          "targets": [{ "expr": "avg(pod_prediction_confidence{metric=\"memory\"})", "legendFormat": "Memory" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "steps": [{"value": 0, "color": "red"}, {"value": 0.5, "color": "yellow"}, {"value": 0.7, "color": "green"}] } } }
        },
        {
          "title": "CPU Predictions",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
          "collapsed": false
        },
        {
          "title": "Predicted CPU Mean per Pod",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
          "targets": [{ "expr": "pod_predicted_cpu_mean", "legendFormat": "{% raw %}{{ namespace }}/{{ pod }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 } } }
        },
        {
          "title": "Predicted CPU Peak per Pod",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
          "targets": [{ "expr": "pod_predicted_cpu_max", "legendFormat": "{% raw %}{{ namespace }}/{{ pod }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 }, "thresholds": { "mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 0.8, "color": "red"}]} } }
        },
        {
          "title": "CPU Prediction Confidence per Pod",
          "type": "bargauge",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
          "targets": [{ "expr": "pod_prediction_confidence{metric=\"cpu\"}", "legendFormat": "{% raw %}{{ namespace }}/{{ pod }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "steps": [{"value": 0, "color": "red"}, {"value": 0.5, "color": "yellow"}, {"value": 0.7, "color": "green"}] } } }
        },
        {
          "title": "Actual vs Predicted CPU",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
          "targets": [
            { "expr": "pod_predicted_cpu_mean", "legendFormat": "{% raw %}Predicted {{ pod }}{% endraw %}" },
            { "expr": "rate(container_cpu_usage_seconds_total{container!=\"\",container!=\"POD\"}[5m])", "legendFormat": "{% raw %}Actual {{ pod }}{% endraw %}" }
          ],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 } } }
        },
        {
          "title": "Memory Predictions",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
          "collapsed": false
        },
        {
          "title": "Predicted Memory Mean per Pod",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
          "targets": [{ "expr": "pod_predicted_memory_mean", "legendFormat": "{% raw %}{{ namespace }}/{{ pod }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 } } }
        },
        {
          "title": "Predicted Memory Peak per Pod",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
          "targets": [{ "expr": "pod_predicted_memory_max", "legendFormat": "{% raw %}{{ namespace }}/{{ pod }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 }, "thresholds": { "mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 0.85, "color": "red"}]} } }
        },
        {
          "title": "Memory Prediction Confidence per Pod",
          "type": "bargauge",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
          "targets": [{ "expr": "pod_prediction_confidence{metric=\"memory\"}", "legendFormat": "{% raw %}{{ namespace }}/{{ pod }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "steps": [{"value": 0, "color": "red"}, {"value": 0.5, "color": "yellow"}, {"value": 0.7, "color": "green"}] } } }
        },
        {
          "title": "Actual vs Predicted Memory",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
          "targets": [
            { "expr": "pod_predicted_memory_mean", "legendFormat": "{% raw %}Predicted {{ pod }}{% endraw %}" },
            { "expr": "container_memory_working_set_bytes{container!=\"\",container!=\"POD\"} / 1073741824", "legendFormat": "{% raw %}Actual {{ pod }}{% endraw %}" }
          ],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 } } }
        },
        {
          "title": "Recommendations",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
          "collapsed": false
        },
        {
          "title": "Active Recommendations",
          "type": "table",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
          "targets": [{ "expr": "pod_recommendation", "format": "table", "instant": true }],
          "datasource": "Prometheus",
          "transformations": [
            { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "namespace": "Namespace", "pod": "Pod", "type": "Recommendation", "Value": "Confidence" } } }
          ]
        },
        {
          "title": "Recommendations by Type",
          "type": "piechart",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
          "targets": [{ "expr": "count by (type) (pod_recommendation)", "legendFormat": "{% raw %}{{ type }}{% endraw %}" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Recommendation Confidence",
          "type": "bargauge",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
          "targets": [{ "expr": "pod_recommendation", "legendFormat": "{% raw %}{{ pod }} ({{ type }}){% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "steps": [{"value": 0, "color": "blue"}, {"value": 0.5, "color": "yellow"}, {"value": 0.8, "color": "red"}] } } }
        }
      ],
      "schemaVersion": 39,
      "templating": { "list": [] },
      "time": { "from": "now-1h", "to": "now" }
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: grafana
  namespace: {{ monitoring_namespace }}
  labels:
    app: grafana
spec:
  replicas: 1
  progressDeadlineSeconds: 1800
  selector:
    matchLabels:
      app: grafana
  template:
    metadata:
      labels:
        app: grafana
    spec:
      securityContext:
        runAsUser: 472
        runAsGroup: 472
        fsGroup: 472
        runAsNonRoot: true
      containers:
        - name: grafana
          image: {{ grafana_image }}
          ports:
            - containerPort: 3000
          env:
            - name: GF_SECURITY_ADMIN_USER
              value: "{{ grafana_admin_user }}"
            - name: GF_SECURITY_ADMIN_PASSWORD
              value: "{{ grafana_admin_password }}"
            - name: GF_SMTP_ENABLED
              value: "{{ grafana_smtp_enabled | lower }}"
            - name: GF_SMTP_HOST
              value: "{{ grafana_smtp_host }}:{{ grafana_smtp_port }}"
            - name: GF_SMTP_USER
              value: "{{ grafana_smtp_user }}"
            - name: GF_SMTP_PASSWORD
              value: "{{ grafana_smtp_password }}"
            - name: GF_SMTP_FROM_ADDRESS
              value: "{{ grafana_smtp_from_address }}"
            - name: GF_SMTP_FROM_NAME
              value: "{{ grafana_smtp_from_name }}"
            - name: GF_SMTP_SKIP_VERIFY
              value: "{{ grafana_smtp_skip_verify | lower }}"
            - name: GF_SMTP_STARTTLS_POLICY
              value: "{{ grafana_smtp_starttls_policy }}"
          volumeMounts:
            - name: datasources
              mountPath: /etc/grafana/provisioning/datasources
            - name: dashboards-provider
              mountPath: /etc/grafana/provisioning/dashboards
            - name: dashboards
              mountPath: /var/lib/grafana/dashboards
      volumes:
        - name: datasources
          configMap:
            name: grafana-datasources
        - name: dashboards-provider
          configMap:
            name: grafana-dashboards-provider
        - name: dashboards
          configMap:
            name: grafana-dashboards
---
apiVersion: v1
kind: Service
metadata:
  name: grafana
  namespace: {{ monitoring_namespace }}
spec:
  type: NodePort
  selector:
    app: grafana
  ports:
    - name: http
      port: 3000
      targetPort: 3000
      nodePort: {{ grafana_nodeport }}
