---
apiVersion: v1
kind: ConfigMap
metadata:
  name: grafana-datasources
  namespace: {{ monitoring_namespace }}
data:
  datasources.yaml: |
    apiVersion: 1
    datasources:
      - name: Prometheus
        type: prometheus
        access: proxy
        url: http://prometheus.{{ monitoring_namespace }}.svc:9090
        isDefault: true
        editable: true
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: grafana-dashboards-provider
  namespace: {{ monitoring_namespace }}
data:
  dashboards.yaml: |
    apiVersion: 1
    providers:
      - name: default
        orgId: 1
        folder: ""
        type: file
        disableDeletion: false
        editable: true
        options:
          path: /var/lib/grafana/dashboards
          foldersFromFilesStructure: false
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: grafana-dashboards
  namespace: {{ monitoring_namespace }}
data:
  k8s-cluster.json: |
    {
      "annotations": { "list": [] },
      "editable": true,
      "title": "Kubernetes Cluster",
      "uid": "k8s-cluster",
      "panels": [
        {
          "title": "Cluster Overview",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
          "collapsed": false
        },
        {
          "title": "Node Count",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
          "targets": [{ "expr": "count(kube_node_info)", "legendFormat": "Nodes" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Ready Nodes",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
          "targets": [{ "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})", "legendFormat": "Ready" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}] } } }
        },
        {
          "title": "Total Pods",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
          "targets": [{ "expr": "count(kube_pod_info)", "legendFormat": "Pods" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Running Pods",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
          "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Running\"})", "legendFormat": "Running" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } }
        },
        {
          "title": "Failed Pods",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
          "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Failed\"}) or vector(0)", "legendFormat": "Failed" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } } }
        },
        {
          "title": "Pending Pods",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
          "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Pending\"}) or vector(0)", "legendFormat": "Pending" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } } }
        },
        {
          "title": "Namespaces",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 0, "y": 5 },
          "targets": [{ "expr": "count(kube_namespace_created)", "legendFormat": "Namespaces" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Deployments",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 4, "y": 5 },
          "targets": [{ "expr": "count(kube_deployment_created)", "legendFormat": "Deployments" }],
          "datasource": "Prometheus"
        },
        {
          "title": "DaemonSets",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 8, "y": 5 },
          "targets": [{ "expr": "count(kube_daemonset_created)", "legendFormat": "DaemonSets" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Services",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 12, "y": 5 },
          "targets": [{ "expr": "count(kube_service_info)", "legendFormat": "Services" }],
          "datasource": "Prometheus"
        },
        {
          "title": "PVCs",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 16, "y": 5 },
          "targets": [{ "expr": "count(kube_persistentvolumeclaim_info) or vector(0)", "legendFormat": "PVCs" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Container Restarts (last 1h)",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 20, "y": 5 },
          "targets": [{ "expr": "sum(increase(kube_pod_container_status_restarts_total[1h]))", "legendFormat": "Restarts" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 5}, {"color": "red", "value": 20}] } } }
        },
        {
          "title": "Node Resources",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
          "collapsed": false
        },
        {
          "title": "CPU Usage per Node (%)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
          "targets": [{ "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{% raw %}{{ instance }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
        },
        {
          "title": "Memory Usage per Node (%)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
          "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "{% raw %}{{ instance }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
        },
        {
          "title": "Disk Usage per Node (%)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
          "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100", "legendFormat": "{% raw %}{{ instance }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
        },
        {
          "title": "System Load (1m avg)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
          "targets": [{ "expr": "node_load1", "legendFormat": "{% raw %}{{ instance }}{% endraw %}" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Network I/O",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
          "collapsed": false
        },
        {
          "title": "Network Receive (bytes/s)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
          "targets": [{ "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|flannel.*|cni.*\"}[5m])", "legendFormat": "{% raw %}{{ instance }} {{ device }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "Bps" } }
        },
        {
          "title": "Network Transmit (bytes/s)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
          "targets": [{ "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|flannel.*|cni.*\"}[5m])", "legendFormat": "{% raw %}{{ instance }} {{ device }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "Bps" } }
        },
        {
          "title": "Network Errors",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
          "targets": [
            { "expr": "rate(node_network_receive_errs_total[5m])", "legendFormat": "{% raw %}RX err {{ instance }}{% endraw %}" },
            { "expr": "rate(node_network_transmit_errs_total[5m])", "legendFormat": "{% raw %}TX err {{ instance }}{% endraw %}" }
          ],
          "datasource": "Prometheus"
        },
        {
          "title": "Network Packets Dropped",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
          "targets": [
            { "expr": "rate(node_network_receive_drop_total[5m])", "legendFormat": "{% raw %}RX drop {{ instance }}{% endraw %}" },
            { "expr": "rate(node_network_transmit_drop_total[5m])", "legendFormat": "{% raw %}TX drop {{ instance }}{% endraw %}" }
          ],
          "datasource": "Prometheus"
        },
        {
          "title": "Pod / Container Metrics",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
          "collapsed": false
        },
        {
          "title": "Container CPU Usage",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
          "targets": [{ "expr": "sum by(pod) (rate(container_cpu_usage_seconds_total{container!=\"\",container!=\"POD\"}[5m]))", "legendFormat": "{% raw %}{{ pod }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "short" } }
        },
        {
          "title": "Container Memory Usage",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
          "targets": [{ "expr": "sum by(pod) (container_memory_working_set_bytes{container!=\"\",container!=\"POD\"})", "legendFormat": "{% raw %}{{ pod }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "bytes" } }
        },
        {
          "title": "Pods by Namespace",
          "type": "piechart",
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 52 },
          "targets": [{ "expr": "count by(namespace) (kube_pod_info)", "legendFormat": "{% raw %}{{ namespace }}{% endraw %}" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Pod Phase Distribution",
          "type": "piechart",
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 52 },
          "targets": [{ "expr": "count by(phase) (kube_pod_status_phase == 1)", "legendFormat": "{% raw %}{{ phase }}{% endraw %}" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Deployment Replicas Available",
          "type": "table",
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 52 },
          "targets": [{ "expr": "kube_deployment_status_replicas_available", "format": "table", "instant": true }],
          "datasource": "Prometheus"
        },
        {
          "title": "Disk I/O per Node",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 60 },
          "collapsed": false
        },
        {
          "title": "Disk Read (bytes/s)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 61 },
          "targets": [{ "expr": "rate(node_disk_read_bytes_total[5m])", "legendFormat": "{% raw %}{{ instance }} {{ device }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "Bps" } }
        },
        {
          "title": "Disk Write (bytes/s)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 61 },
          "targets": [{ "expr": "rate(node_disk_written_bytes_total[5m])", "legendFormat": "{% raw %}{{ instance }} {{ device }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "Bps" } }
        },
        {
          "title": "Pod Status Table",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 69 },
          "collapsed": false
        },
        {
          "title": "All Pods (status)",
          "type": "table",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 70 },
          "targets": [{ "expr": "kube_pod_status_phase", "format": "table", "instant": true }],
          "datasource": "Prometheus"
        }
      ],
      "schemaVersion": 39,
      "templating": { "list": [] },
      "time": { "from": "now-1h", "to": "now" }
    }
  openstack.json: |
    {
      "annotations": { "list": [] },
      "editable": true,
      "title": "OpenStack Infrastructure",
      "uid": "openstack-infra",
      "panels": [
        {
          "title": "Service Status",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
          "collapsed": false
        },
        {
          "title": "OpenStack Exporter",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
          "targets": [{ "expr": "up{job=\"openstack\"}", "legendFormat": "Exporter" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}] } }
        },
        {
          "title": "Gnocchi Exporter",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
          "targets": [{ "expr": "up{job=\"gnocchi\"}", "legendFormat": "Gnocchi" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}] } }
        },
        {
          "title": "Total VMs",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
          "targets": [{ "expr": "openstack_nova_total_vms", "legendFormat": "VMs" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Running VMs",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
          "targets": [{ "expr": "openstack_nova_running_vms", "legendFormat": "Running" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } }
        },
        {
          "title": "Compute Agents",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
          "targets": [{ "expr": "openstack_nova_agent_state{service=\"nova-compute\"}", "legendFormat": "{% raw %}{{ hostname }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}] } }
        },
        {
          "title": "Neutron Agents",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
          "targets": [{ "expr": "openstack_neutron_agent_state", "legendFormat": "{% raw %}{{ hostname }}-{{ service }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}] } }
        },
        {
          "title": "Nova Quotas & Resources",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
          "collapsed": false
        },
        {
          "title": "vCPUs Used vs Max",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
          "targets": [
            { "expr": "openstack_nova_limits_vcpus_used", "legendFormat": "{% raw %}Used {{ tenant }}{% endraw %}" },
            { "expr": "openstack_nova_limits_vcpus_max", "legendFormat": "{% raw %}Max {{ tenant }}{% endraw %}" }
          ],
          "datasource": "Prometheus"
        },
        {
          "title": "RAM Used vs Max (MB)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
          "targets": [
            { "expr": "openstack_nova_limits_memory_used", "legendFormat": "{% raw %}Used {{ tenant }}{% endraw %}" },
            { "expr": "openstack_nova_limits_memory_max", "legendFormat": "{% raw %}Max {{ tenant }}{% endraw %}" }
          ],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "decmbytes" } }
