            { "expr": "openstack_nova_limits_instances_used", "legendFormat": "{% raw %}Used {{ tenant }}{% endraw %}" },
            { "expr": "openstack_nova_limits_instances_max", "legendFormat": "{% raw %}Max {{ tenant }}{% endraw %}" }
          ],
          "datasource": "Prometheus"
        },
        {
          "title": "Nova Server Local Disk (GB)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
          "targets": [{ "expr": "openstack_nova_server_local_gb", "legendFormat": "{% raw %}{{ name }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "decgbytes" } }
        },
        {
          "title": "Networking",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
          "collapsed": false
        },
        {
          "title": "Networks",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 0, "y": 23 },
          "targets": [{ "expr": "openstack_neutron_networks", "legendFormat": "Networks" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Subnets",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 4, "y": 23 },
          "targets": [{ "expr": "openstack_neutron_subnets", "legendFormat": "Subnets" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Routers",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 8, "y": 23 },
          "targets": [{ "expr": "openstack_neutron_routers", "legendFormat": "Routers" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Ports",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 12, "y": 23 },
          "targets": [{ "expr": "openstack_neutron_ports", "legendFormat": "Ports" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Floating IPs",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 16, "y": 23 },
          "targets": [{ "expr": "openstack_neutron_floating_ips", "legendFormat": "Floating IPs" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Security Groups",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 20, "y": 23 },
          "targets": [{ "expr": "openstack_neutron_security_groups", "legendFormat": "Sec Groups" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Cinder Storage",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
          "collapsed": false
        },
        {
          "title": "Volumes",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 0, "y": 28 },
          "targets": [{ "expr": "openstack_cinder_volumes", "legendFormat": "Volumes" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Volume Size (GB)",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 4, "y": 28 },
          "targets": [{ "expr": "openstack_cinder_volume_size_gb", "legendFormat": "{% raw %}{{ name }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "unit": "decgbytes" } }
        },
        {
          "title": "Volume Status",
          "type": "table",
          "gridPos": { "h": 6, "w": 8, "x": 8, "y": 28 },
          "targets": [{ "expr": "openstack_cinder_volume_status", "format": "table", "instant": true }],
          "datasource": "Prometheus"
        },
        {
          "title": "Snapshots",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 16, "y": 28 },
          "targets": [{ "expr": "openstack_cinder_snapshots", "legendFormat": "Snapshots" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Cinder Agent State",
          "type": "stat",
          "gridPos": { "h": 4, "w": 4, "x": 20, "y": 28 },
          "targets": [{ "expr": "openstack_cinder_agent_state", "legendFormat": "{% raw %}{{ hostname }}-{{ service }}{% endraw %}" }],
          "datasource": "Prometheus",
          "fieldConfig": { "defaults": { "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}] } }
        },
        {
          "title": "Glance Images",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
          "collapsed": false
        },
        {
          "title": "Total Images",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 0, "y": 35 },
          "targets": [{ "expr": "openstack_glance_images", "legendFormat": "Images" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Image Sizes",
          "type": "table",
          "gridPos": { "h": 6, "w": 18, "x": 6, "y": 35 },
          "targets": [{ "expr": "openstack_glance_image_bytes", "format": "table", "instant": true }],
          "datasource": "Prometheus"
        },
        {
          "title": "Keystone",
          "type": "row",
          "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
          "collapsed": false
        },
        {
          "title": "Projects",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 0, "y": 42 },
          "targets": [{ "expr": "openstack_identity_projects", "legendFormat": "Projects" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Users",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 6, "y": 42 },
          "targets": [{ "expr": "openstack_identity_users", "legendFormat": "Users" }],
          "datasource": "Prometheus"
        },
        {
          "title": "Domains",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 12, "y": 42 },
          "targets": [{ "expr": "openstack_identity_domains", "legendFormat": "Domains" }],
          "datasource": "Prometheus"
