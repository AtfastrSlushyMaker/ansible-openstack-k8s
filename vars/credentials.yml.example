# Example OpenStack credentials file
# Copy this to vars/credentials.yml and fill in real values when running.
# Do NOT commit your real `vars/credentials.yml` if it contains secrets.

auth:
  auth_url: "https://openstack.example.org:5000/v3"
  username: "your-username"
  password: "your-password"
  project_name: "your-project"
  user_domain_name: "Default"
  project_domain_name: "Default"
  region_name: "RegionOne"

# Optional settings
identity_api_version: 3

# If you prefer using a clouds.yml file (openstacksdk), you can omit this and
# configure `clouds.yaml` instead. This example is kept simple for local runs.
