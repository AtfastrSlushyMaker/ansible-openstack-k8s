apiVersion: v1
kind: Pod
metadata:
  name: nginx
  namespace: {{ nginx_namespace }}
  labels:
    app: nginx
spec:
  containers:
    - name: nginx
      image: nginx:latest
      ports:
        - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: nginx
  namespace: {{ nginx_namespace }}
spec:
  type: NodePort
  selector:
    app: nginx
  ports:
    - name: http
      port: 80
      targetPort: 80
{% if nginx_nodeport is defined and nginx_nodeport | int > 0 %}
      nodePort: {{ nginx_nodeport }}
{% endif %}
